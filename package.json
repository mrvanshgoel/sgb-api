{
  "name": "sgb-api",
  "version": "1.0.0",
  "description": "Open-source Sovereign Gold Bond (SGB) REST API for India — production-ready, self-hostable",
  "main": "dist/app.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc && node -e \"require('fs').cpSync('src/data/sgb-series.json','dist/data/sgb-series.json')\"",
    "start": "node dist/app.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "validate:data": "tsx scripts/validate-data.ts",
    "build:data": "tsx scripts/build-data.ts"
  },
  "keywords": [
    "sgb",
    "sovereign-gold-bond",
    "rbi",
    "india",
    "gold",
    "api",
    "fastify"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/swagger": "^9.8.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.10.0",
    "fuse.js": "^7.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fastify/swagger-ui": "^6.1.0",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
