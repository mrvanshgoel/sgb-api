# ─── SGB API Configuration ────────────────────────────────────────────────

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ── Market Data Provider ──────────────────────────────────────────────────
# Options:
#   null  (default) — no live market data; /market/* returns honest
#                     null-shaped responses with a reason
#   groww — Groww's OFFICIAL Trade API (https://groww.in/trade-api/docs).
#           Requires the user's OWN paid Trading API subscription.
#           Never scrapes.
MARKET_DATA_PROVIDER=null

# Groww credentials (only if MARKET_DATA_PROVIDER=groww).
# Either a daily access token (expires 6:00 AM IST daily)…
GROWW_ACCESS_TOKEN=
# …or an API key (see Groww docs for key+secret token flow)
GROWW_API_KEY=

# ── Gold Price Provider ───────────────────────────────────────────────────
# Options:
#   null   (default) — /gold returns null-shaped response with a reason
#   metals — metals.dev (free tier: 100 req/month; the 15-min cache TTL
#            keeps one instance within quota). https://metals.dev
GOLD_PRICE_PROVIDER=null
METALS_API_KEY=

# ── Cache ─────────────────────────────────────────────────────────────────
# Default cache is in-memory (no external services needed).
# TTLs in seconds: static series data never expires by design.
MARKET_DATA_TTL=300
GOLD_PRICE_TTL=900

# Optional Redis URL for a custom Redis CacheProvider
REDIS_URL=

# ── NSE Outbound Networking ───────────────────────────────────────────────
# NSE sits behind Akamai Bot Manager, which blocks requests from SHARED cloud
# egress IPs (Render/Heroku/most PaaS free tiers pool their outbound IPs).
# Identical code that works from a laptop returns HTTP 403 from those IPs.
# The fix is a networking one: send NSE requests from an IP the upstream trusts.
#
# Leave BOTH unset for today's behavior (direct connection). Set exactly ONE —
# they are mutually exclusive. Config is validated at startup; invalid values
# stop the process rather than silently 403-ing later.
#
# Route NSE requests through an outbound proxy that owns a clean/dedicated IP.
# Supports http, https, socks5, socks5h — credentials optional and never logged.
#   NSE_PROXY_URL=http://user:pass@proxy.example.com:8080
NSE_PROXY_URL=
# Set to 'true' if the proxy rotates its exit IP on each request.
NSE_PROXY_ROTATING=
#
# OR bind outbound sockets to a specific local source IP — use on a host with a
# dedicated/static egress NIC (e.g. a VPS or a Render instance with a static IP).
#   NSE_LOCAL_ADDRESS=203.0.113.10
NSE_LOCAL_ADDRESS=

